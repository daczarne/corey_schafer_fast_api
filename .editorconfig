# This file is for unifying the coding style for different editors and IDEs
# See editorconfig.org

root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.css]
indent_size = 2

[*.html]
indent_size = 2

[*.js]
indent_size = 2

[*.md]
indent_size = 2
trim_trailing_whitespace = false

[*.py]
trim_trailing_whitespace = false

[*.{yaml,yml}]
indent_size = 2
